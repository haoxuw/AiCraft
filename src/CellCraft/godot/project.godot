; CellCraft — 2D multiplayer draw-shapes-to-life game, Godot 4.3
;
; Single project, three entry scenes launched via --main-scene:
;   scenes/client.tscn  — GUI player client (default)
;   scenes/server.tscn  — headless authoritative server
;   scenes/agent.tscn   — headless AI agent per uncontrolled entity
;
; All three share scripts/shared/. See docs/ARCHITECTURE.md.

config_version=5

[application]

config/name="CellCraft"
run/main_scene="res://scenes/client.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="forward_plus"
